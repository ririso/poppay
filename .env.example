# PayPay API設定（開発指針 6.セキュリティ方針に準拠）
# 注意: これらの値は絶対にフロントエンドに露出させない（NEXT_PUBLIC_プレフィックスを付けない）
PAYPAY_API_KEY=your_paypay_api_key_here
PAYPAY_API_SECRET=your_paypay_api_secret_here
PAYPAY_MERCHANT_ID=your_paypay_merchant_id_here

# PayPay環境設定
# 本番環境: true, Sandbox環境: false, ステージング環境: false
PAYPAY_PRODUCTION_MODE=false

# PayPay エンドポイント設定（開発指針 5.環境構成に準拠）
# Sandbox: https://stg-api.sandbox.paypay.ne.jp/
# Staging: https://stg-api.paypay.ne.jp/
# Production: https://api.paypay.ne.jp/
PAYPAY_API_BASE_URL=https://stg-api.sandbox.paypay.ne.jp/

# Supabase設定（開発指針 3.技術スタックに準拠）
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_key_here

# データベース設定
DATABASE_URL=your_supabase_database_url_here

# アプリケーション設定
# 管理者認証用（開発指針 6.セキュリティ方針: 最低限のパスワード認証）
ADMIN_PASSWORD=your_secure_admin_password_here

# セッション管理
NEXTAUTH_SECRET=your_nextauth_secret_32_chars_or_more
NEXTAUTH_URL=http://localhost:3000

# Webhook設定（開発指針 4.決済フロー: Webhook受信）
WEBHOOK_BASE_URL=https://your-domain.vercel.app

# テナント設定（開発指針 7.データ設計: SaaS化を見据えた設計）
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# セキュリティ設定
# PayPay IPホワイトリスト有効化（開発指針 6.セキュリティ方針）
ENABLE_PAYPAY_IP_WHITELIST=true

# ログレベル設定
LOG_LEVEL=info