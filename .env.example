# PayPay Configuration
PAYPAY_CLIENT_ID=your_client_id_here
PAYPAY_CLIENT_SECRET=your_client_secret_here
PAYPAY_ENV=STAGING

# PayPay Webhook Secret (for signature verification)
PAYPAY_WEBHOOK_SECRET=your_webhook_secret_key

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Webhook endpoint for PayPay notifications
NEXT_PUBLIC_WEBHOOK_URL=http://localhost:3000/api/webhook

# Admin Configuration (for future use)
ADMIN_PASSWORD_HASH=your_admin_password_hash